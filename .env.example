# Copy this file to .env and fill in your values:
#   Copy-Item .env.example .env

# OpenAI (required for CrewAI agents)
OPENAI_API_KEY=sk-your-key-here

# LLM model (provider/model or shorthand like gpt-4o-mini)
MODEL=gpt-4o-mini

# ML pipeline inputs (optional — you can also pass at runtime)
DATASET_PATH=data/titanic.csv
TARGET_COLUMN=Survived
